{
  "name": "Noctua",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#abb2bf",
    "variable.readonly": "#f47067",
    "property": "#abb2bf",
    "property.readonly": "#f47067",
    "function": "#61afef",
    "method": "#61afef",
    "class": "#e5c07b",
    "interface": "#e5c07b",
    "type": "#e5c07b",
    "enum": "#e5c07b",
    "enumMember": "#f47067",
    "namespace": "#e5c07b",
    "keyword": "#c678dd",
    "parameter": "#abb2bf",
    "typeParameter": "#e5c07b"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4b5a6a", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.other.using",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#c678dd", "fontStyle": "italic" }
    },
    {
      "name": "Import / Export keywords",
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as"],
      "settings": { "foreground": "#c678dd", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp"
      ],
      "settings": { "foreground": "#98c379" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape", "constant.other.placeholder"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex"],
      "settings": { "foreground": "#f47067" }
    },
    {
      "name": "Boolean / Null / Undefined",
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined", "constant.language"],
      "settings": { "foreground": "#f47067" }
    },
    {
      "name": "Function names",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#61afef" }
    },
    {
      "name": "Function call",
      "scope": ["meta.function-call"],
      "settings": { "foreground": "#61afef" }
    },
    {
      "name": "Class / Type / Interface names",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.namespace",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#e5c07b" }
    },
    {
      "name": "Type annotation (TypeScript)",
      "scope": [
        "meta.type.annotation",
        "meta.type.parameters",
        "entity.name.type.alias"
      ],
      "settings": { "foreground": "#e5c07b" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Constants",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#f47067" }
    },
    {
      "name": "Object properties",
      "scope": ["variable.other.property", "meta.object-literal.key", "support.type.property-name"],
      "settings": { "foreground": "#abb2bf" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#abb2bf", "fontStyle": "" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.accessor"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.definition"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "JSX / HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": { "foreground": "#e06c8a" }
    },
    {
      "name": "JSX / HTML Attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes"
      ],
      "settings": { "foreground": "#e5c07b", "fontStyle": "italic" }
    },
    {
      "name": "JSX Expression braces",
      "scope": ["punctuation.section.embedded", "meta.embedded.expression"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "CSS Selectors",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#e06c8a" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#61afef" }
    },
    {
      "name": "CSS Values",
      "scope": ["support.constant.property-value.css", "meta.property-value.css"],
      "settings": { "foreground": "#98c379" }
    },
    {
      "name": "CSS Numbers / Units",
      "scope": ["constant.numeric.css", "keyword.other.unit.css"],
      "settings": { "foreground": "#f47067" }
    },
    {
      "name": "CSS Colors",
      "scope": ["constant.other.color.rgb-value.css", "constant.other.color.css"],
      "settings": { "foreground": "#f47067" }
    },
    {
      "name": "JSON Keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#e06c8a" }
    },
    {
      "name": "JSON String values",
      "scope": ["string.quoted.double.json"],
      "settings": { "foreground": "#98c379" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#c678dd", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#e5c07b", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#abb2bf", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#98c379" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": { "foreground": "#61afef" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#f47067", "fontStyle": "strikethrough" }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#e06c8a", "fontStyle": "italic" }
    },
    {
      "name": "this / self",
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": { "foreground": "#e06c8a", "fontStyle": "italic" }
    },
    {
      "name": "super",
      "scope": ["variable.language.super"],
      "settings": { "foreground": "#c678dd", "fontStyle": "italic" }
    }
  ],
  "colors": {

