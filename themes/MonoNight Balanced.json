  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#676E95", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "keyword.operator.bitwise",
        "keyword.other.debugger",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Storage type (class, function, var)",
      "scope": ["storage.type.class", "storage.type.function", "storage.type.ts", "storage.type.js"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "string.regexp"
      ],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "Template expression / embedded",
      "scope": [
        "meta.template.expression",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal"
      ],
      "settings": { "foreground": "#FF6188" }
    },
    {
      "name": "Constants — boolean, null, undefined",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": { "foreground": "#F78C6C", "fontStyle": "italic" }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.function-call entity.name.function",
        "support.function",
        "support.function.console"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameter"
      ],
      "settings": { "foreground": "#A6ACCD", "fontStyle": "italic" }
    },
    {
      "name": "Variables — local/readwrite",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#A6ACCD" }
    },
    {
      "name": "Variables — object references",
      "scope": [
        "variable.other.object"
      ],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Variables — constants (const)",
      "scope": [
        "variable.other.constant"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Variables — property access (dot notation)",
      "scope": [
        "variable.other.property"
      ],
      "settings": { "foreground": "#A6ACCD" }
    },
    {
      "name": "Object literal keys",
      "scope": [
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Support property names (CSS-in-JS, etc)",
      "scope": [
        "support.type.property-name"
      ],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Types / Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "meta.type.annotation",
        "meta.type.parameters"
      ],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Type annotations / generics",
      "scope": [
        "entity.name.type.ts",
        "entity.name.type.js",
        "meta.type.annotation.ts",
        "support.type.primitive",
        "keyword.type"
      ],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.ts meta.decorator"
      ],
      "settings": { "foreground": "#82AAFF", "fontStyle": "italic" }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.relational",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.optional"
      ],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.separator.comma",
        "punctuation.terminator.statement"
      ],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "name": "Built-ins / support",
      "scope": [
        "support.type.builtin",
        "support.class.builtin",
        "support.variable.dom",
        "support.variable.property.dom",
        "support.function.dom"
      ],
      "settings": { "foreground": "#56B6C2" }
    },
    {
      "name": "Import / export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "name": "Module paths",
      "scope": [
        "string.quoted.single.js meta.import",
        "string.quoted.double.js meta.import"
      ],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "HTML tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": { "foreground": "#FF6188" }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes"
      ],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "HTML attribute values",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#FF6188" }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "CSS values / units",
      "scope": [
        "support.constant.property-value.css",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": { "foreground": "#F78C6C" }
    },
    {
      "name": "CSS colors",
      "scope": ["constant.other.color.rgb-value.css"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.json meta.structure.dictionary.value"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Markdown headings",
      "scope": ["entity.name.section.markdown", "markup.heading"],
      "settings": { "foreground": "#C792EA", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#FFCB6B", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#F78C6C", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Invalid / Errors",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#E06C75", "fontStyle": "underline" }
    }
  ],

  "semanticTokenColors": {
    "class":              { "foreground": "#FFCB6B" },
    "interface":          { "foreground": "#FFCB6B", "fontStyle": "italic" },
    "typeParameter":      { "foreground": "#FFCB6B" },
    "enum":               { "foreground": "#FFCB6B" },
    "enumMember":         { "foreground": "#89DDFF" },
    "function":           { "foreground": "#82AAFF" },
    "method":             { "foreground": "#82AAFF" },
    "property":           { "foreground": "#A6ACCD" },
    "property.readonly":  { "foreground": "#89DDFF" },
    "variable":           { "foreground": "#A6ACCD" },
    "variable.constant":  { "foreground": "#82AAFF" },
    "parameter":          { "foreground": "#A6ACCD", "fontStyle": "italic" },
    "namespace":          { "foreground": "#56B6C2" },
    "module":             { "foreground": "#56B6C2" },
    "decorator":          { "foreground": "#82AAFF", "fontStyle": "italic" },
    "regexp":             { "foreground": "#FF6188" }
  }
}